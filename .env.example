# =============================================================
# 🪙 الليرة الآن - Environment Variables
# نسخ هذا الملف إلى .env وتعديل القيم
# NEVER commit .env to git!
# =============================================================

# ---- App ----
NODE_ENV=production
APP_NAME=الليرة الآن
APP_URL=https://liranow.sy

# ---- Database ----
POSTGRES_DB=liranow_db
POSTGRES_USER=liranow_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_2026

# ---- Redis ----
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_2026

# ---- JWT Authentication ----
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# ---- Admin Default Account (first boot only) ----
ADMIN_EMAIL=admin@liranow.sy
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD_2026
ADMIN_NAME=مدير النظام

# ---- Price Fetcher ----
PRICE_FETCH_INTERVAL_MINUTES=5
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key_here
GOLD_API_KEY=your_gold_api_key_here

# ---- CORS ----
ALLOWED_ORIGINS=https://liranow.sy,https://admin.liranow.sy,https://app.liranow.sy

# ---- pgAdmin (dev only) ----
PGADMIN_EMAIL=admin@liranow.sy
PGADMIN_PASSWORD=CHANGE_THIS_PGADMIN_PASSWORD

# ---- SSL Domain ----
DOMAIN=liranow.sy
CERTBOT_EMAIL=admin@liranow.sy
